# ─── Public (embedded in client bundle) ───────────────────────────────────────
NEXT_PUBLIC_FEATURE_WEBGL_BG=1
NEXT_PUBLIC_WHATSAPP=+94701234567
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Site ─────────────────────────────────────────────────────────────────────
SITE_URL=https://lakeviewvillatangalle.com

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth.js ──────────────────────────────────────────────────────────────────
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# ─── Initial Admin Credentials (used by prisma/seed.ts) ──────────────────────
ADMIN_EMAIL=admin@lakeviewvillatangalle.com
ADMIN_PASSWORD=changeme123!

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── Upstash Redis ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# ─── OpenRouter AI (Blog Generation) ─────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free