{
  "id": "/?source=pwa",
  "name": "Lake View Villa Tangalle",
  "short_name": "LakeViewVilla",
  "description": "Private villa on a serene lagoon in Tangalle. Panoramic views, A/C rooms, fast Wi-Fi, chef services.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "standalone",
    "browser"
  ],
  "background_color": "#ffffff",
  "theme_color": "#0a0f10",
  "categories": [
    "travel",
    "lifestyle",
    "hospitality"
  ],
  "dir": "ltr",
  "lang": "en",
  "icons": [
